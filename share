@router.get("/me")
def get_me(user: dict = Depends(get_current_user)):
    """return the decoded JWT payload"""
    return {
        "sub": user.get("sub"),
        "email": user.get("email"),
        "name": user.get("name"),
        "given_name": user.get("given_name"),
        "family_name": user.get("family_name"),
    }
