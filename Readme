    if creds is not None and creds.scheme.lower() == "bearer":
        token = creds.credentials
        try:
            payload = _get_verifier().verify(token)
            return payload
        except AuthError as exc:
            logger.warning("auth_rejected", path=request.url.path, ip=client_ip, reason=exc.reason)
            raise HTTPException(
                status_code=status.HTTP_401_UNAUTHORIZED,
                detail="Invalid or expired token",
                headers={"WWW-Authenticate": "Bearer"},
            ) from exc

    # Fallback: session cookie -> call userinfo endpoint
    token_from_session = request.session.get("access_token") if hasattr(request, "session") else None
    if token_from_session:
        import httpx
        settings = _get_settings()
        try:
            resp = httpx.get(
                str(settings.oidc_userinfo_endpoint),
                headers={"Authorization": f"Bearer {token_from_session}"},
                verify=False,
                timeout=10,
            )
            if resp.status_code == 200:
                return resp.json()
            logger.warning("userinfo_failed", status=resp.status_code)
        except Exception as exc:
            logger.warning("userinfo_error", error=str(exc))

    logger.warning("auth_missing", path=request.url.path, ip=client_ip)
    raise HTTPException(
        status_code=status.HTTP_401_UNAUTHORIZED,
        detail="Missing or malformed Authorization header",
        headers={"WWW-Authenticate": "Bearer"},
    )
